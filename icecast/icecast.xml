<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<icecast>
  <hostname>localhost</hostname>
  <location>Slobozia</location>
  <admin>admin@campus.ro</admin>
  <port>8000</port>
  <bind_address>0.0.0.0</bind_address>
  <admin_user>admin</admin_user>
  <admin_password>adminadmin</admin_password>
  <relay_password>hackme</relay_password>
  <limits>
    <sources>10</sources>
    <clients>500</clients>
    <queue_size>524288</queue_size>
    <burst_size>65536</burst_size>
  </limits>
  <mount>
    <name>/stream</name>
    <max_listeners>-1</max_listeners>
    <source_password>admin</source_password>
  </mount>
  <mount>
    <name>/dj-skije</name>
    <max_listeners>-1</max_listeners>
    <source_password>cmonica</source_password>
    <fallback_mount>/stream</fallback_mount>
  </mount>
  <loglevel>info</loglevel>
  <accesslog>/usr/local/icecast/logs/access.log</accesslog>
  <errorlog>/usr/local/icecast/logs/error.log</errorlog>
</icecast>