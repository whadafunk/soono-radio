<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<icecast>
  <hostname>localhost</hostname>
  <location>Slobozia</location>
  <admin>admin@campus.ro</admin>
  <limits>
    <sources>10</sources>
    <clients>500</clients>
    <queue-size>524288</queue-size>
    <burst-size>65536</burst-size>
  </limits>
  <authentication>
    <source-password>cmonica</source-password>
    <relay-password>hackme</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>adminadmin</admin-password>
  </authentication>
  <listen-socket>
    <port>8000</port>
    <bind-address>0.0.0.0</bind-address>
    <ssl>1</ssl>
  </listen-socket>
  <listen-socket>
    <port>8001</port>
    <bind-address>0.0.0.0</bind-address>
  </listen-socket>
  <mount>
    <mount-name>/stream</mount-name>
    <max-listeners>-1</max-listeners>
    <stream-name>mf radio</stream-name>
    <stream-description>plays shit</stream-description>
    <genre>varios</genre>
    <bitrate>256</bitrate>
    <type>mpeg</type>
    <public>0</public>
  </mount>
  <paths>
    <basedir>/usr/share/icecast2</basedir>
    <logdir>/usr/local/icecast/logs</logdir>
    <webroot>/etc/icecast2/web</webroot>
    <adminroot>/etc/icecast2/admin</adminroot>
    <ssl-certificate>/etc/icecast2/certs/gigi-serv.pem</ssl-certificate>
  </paths>
  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
  </logging>
</icecast>