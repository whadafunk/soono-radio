<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<icecast>
  <hostname>localhost</hostname>
  <location>Slobozia</location>
  <admin>admin@campus.ro</admin>
  <limits>
    <sources>10</sources>
    <clients>500</clients>
    <queue-size>524288</queue-size>
    <burst-size>65536</burst-size>
  </limits>
  <authentication>
    <source-password>cmonica</source-password>
    <relay-password>hackme</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>adminadmin</admin-password>
  </authentication>
  <listen-socket>
    <port>8000</port>
    <bind-address>0.0.0.0</bind-address>
  </listen-socket>
  <mount>
    <mount-name>/stream</mount-name>
    <max-listeners>-1</max-listeners>
  </mount>
  <mount>
    <mount-name>/dj-skije</mount-name>
    <max-listeners>-1</max-listeners>
    <password>giginet</password>
    <fallback-mount>/stream</fallback-mount>
  </mount>
  <paths>
    <basedir>/usr/local/icecast</basedir>
    <logdir>/usr/local/icecast/logs</logdir>
    <webroot>/usr/local/icecast/share/icecast/web</webroot>
    <adminroot>/usr/local/icecast/share/icecast/admin</adminroot>
  </paths>
  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
  </logging>
</icecast>