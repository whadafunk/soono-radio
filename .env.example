# Copy this file to .env and fill in your values.
# .env is gitignored — this file is the committed reference.

# ── Icecast credentials ────────────────────────────────────────────────────────
# Must match the <authentication> block in icecast/icecast.xml.
# Change these before going to production — defaults are publicly known.
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASS=adminadmin

# ── Internal service networking ────────────────────────────────────────────────
# Docker Compose service names — do not change unless you rename services.
ICECAST_URL=http://icecast:8000
LS_HARBOR_URL=http://liquidsoap:8005
LS_API_URL=http://api:3000
DOCKER_PROXY_URL=http://socket-proxy:2375

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins the browser is allowed to call the API from.
# Add your production domain here, e.g. https://radio.example.com
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:3000

# ── Paths ─────────────────────────────────────────────────────────────────────
# Mount point for the audio library inside the container (matches volumes block).
LS_MEDIA_DIR=/media

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between the API and LiquidSoap harbor webhook.
# Leave empty to disable signature verification (dev only).
LS_HARBOR_SECRET=

# ── Integrations (optional) ───────────────────────────────────────────────────
# AcoustID API key for audio fingerprinting / metadata lookup.
# Get one free at https://acoustid.org/login
# Can also be set in the Integrations settings page inside the app.
ACOUSTID_API_KEY=
